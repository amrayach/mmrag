POSTGRES_USER=rag_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

RAG_DB=rag
N8N_DB=n8n

# Host-bound localhost ports (frozen)
PORT_N8N=56150
PORT_OPENWEBUI=56151
PORT_FILEBROWSER=56152
PORT_ADMINER=56153
PORT_PG=56154
PORT_ASSETS=56157
PORT_RAG_GATEWAY=56155
PORT_CONTROLCENTER=56156

# Tailnet assets base URL used in answers (computed at runtime)
PUBLIC_ASSETS_BASE_URL=https://YOUR_TAILSCALE_HOSTNAME:8454

# Ollama internal URL
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_TEXT_MODEL=gemma4:26b
OLLAMA_VISION_MODEL=qwen2.5vl:7b
OLLAMA_EMBED_MODEL=bge-m3

# Set to "true" to keep the default Googlebot UA for RSS fetching.
# Required to bypass bot protection on some feeds.
SPOOF_USER_AGENT=true

# Enable RSS image captioning via vision model (qwen2.5vl:7b).
CAPTION_IMAGES=true

# Ollama keeps all 3 models loaded (~28 GB with gemma4:26b). Set to 1 on low-memory systems.
# OLLAMA_MAX_LOADED_MODELS=3

# n8n internal webhook used by rag-gateway
N8N_CHAT_WEBHOOK_URL=http://n8n:5678/webhook/rag-chat

# n8n requires a 64 hex char encryption key. Generate: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS

# Tailscale hostname for external URL generation
TAILSCALE_HOSTNAME=spark-e010.tail907fce.ts.net

# OpenWebUI secret must stay stable across restarts for sessions/JWTs.
# Generate once: openssl rand -hex 32
WEBUI_SECRET_KEY=CHANGE_ME_STABLE_WEBUI_SECRET

# Option 3C hybrid OpenWebUI access is disabled by default.
# When enabled, demo-site remains the public/root gate and OpenWebUI stays behind it.
DEMO_SITE_OPENWEBUI_ENABLED=false
# Demo-site access-code admin API. The admin token is used by demo-site and by
# Control Center's server-side proxy; it must never be exposed in frontend code.
# Generate once: openssl rand -hex 32
DEMO_SITE_ADMIN_TOKEN=CHANGE_ME_DEMO_ADMIN_TOKEN
# Control Center uses the internal compose URL by default. If running Control
# Center on the host, override this with http://127.0.0.1:56158.
CONTROL_CENTER_DEMO_SITE_URL=http://demo-site:3000
# Optional public URL returned by Control Center demo-access responses for UI link building.
DEMO_PUBLIC_URL=https://YOUR_TAILSCALE_HOSTNAME:8443
OPENWEBUI_URL=http://openwebui:8080
OPENWEBUI_ADMIN_EMAIL=
OPENWEBUI_ADMIN_PASSWORD=
OPENWEBUI_TRUSTED_EMAIL_HEADER=X-Demo-Email
OPENWEBUI_TRUSTED_NAME_HEADER=X-Demo-Name

# OpenWebUI trusted-header auth for the hybrid root-mux path.
WEBUI_AUTH=true
WEBUI_AUTH_TRUSTED_EMAIL_HEADER=X-Demo-Email
WEBUI_AUTH_TRUSTED_NAME_HEADER=X-Demo-Name
ENABLE_FORWARD_USER_INFO_HEADERS=true
JWT_EXPIRES_IN=24h

# Optional per-reviewer rag-gateway quota for hybrid demos.
RAG_DEMO_RATE_LIMIT_ENABLED=false
RAG_DEMO_MAX_QUERIES_PER_HOUR=10

# Linux user/group for file permissions (ammer typically 1000:1000)
PUID=1000
PGID=1000
