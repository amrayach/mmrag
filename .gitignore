# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.venv-phase0/

# OS
.DS_Store
Thumbs.db
data/demo_snapshot*.sql

# Eval per-prompt outputs (keep summary.json, scorecard.md, run.json, prompts.json)
data/eval/runs/*/p[0-9]*.json
data/eval/runs/_latest_progress.log

# RAG retrieval traces (only written when RAG_TRACE=true; large JSONL files)
data/rag-traces/*
!data/rag-traces/.gitkeep

# Trace inspector reports (generated by scripts/inspect_retrieval_trace.py)
data/eval/trace_inspections/*
!data/eval/trace_inspections/.gitkeep

# Demo health check runtime reports
data/eval/demo_health/latest.json
data/eval/demo_health/latest.md
data/eval/demo_health/history/*_health.json
data/eval/demo_health/history/*_health.md
data/eval/demo_health/notifications.log
data/eval/demo_health/*.tmp
!data/eval/demo_health/.gitkeep
!data/eval/demo_health/history/.gitkeep

